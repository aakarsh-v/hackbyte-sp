# SpacetimeDB — database name (must match `spacetime publish <name>`)
SPACETIME_DATABASE=devopsai

# HTTP API base (no trailing slash). Examples:
# - Docker Compose + embedded DB: leave unset (compose defaults to http://spacetime:3000) and use
#   `docker compose --profile local-spacetime ...` so spacetime + st-init run.
# - Maincloud: set URL and bearer token from `spacetime login` (see docs/SPACETIMEDB.md).
# SPACETIME_HTTP_URL=https://maincloud.spacetimedb.com
# SPACETIME_BEARER_TOKEN=

# Host-only local Spacetime (not Compose):
# SPACETIME_HTTP_URL=http://127.0.0.1:3004

# Google AI Studio — create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id (check AI Studio for current names, e.g. gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Policy: allow docker compose / docker restart style commands in approved runbooks
ALLOW_DOCKER_EXEC=true

# Max lines retained for analysis buffer (must match module trim policy; default 2000)
LOG_BUFFER_MAX=2000

# CORS (comma-separated origins for web UI)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# AWS CloudWatch Logs Integration (Optional)
# -----------------------------------------------------------------------------
# Set this to your CloudWatch Log Group name (e.g. /aws/ec2/production-app) to
# enable cloud log polling. Polled events will flow into SpacetimeDB and trigger
# the AI just like local container logs.
# CW_LOG_GROUP=
# CW_LOG_STREAM_PREFIX=
# CW_POLL_INTERVAL_S=15
# CW_INITIAL_LOOKBACK_S=300
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
