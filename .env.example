# Google AI Studio — create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id (check AI Studio for current names, e.g. gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Policy: allow docker compose / docker restart style commands in approved runbooks
ALLOW_DOCKER_EXEC=true

# Max lines retained for analysis buffer
LOG_BUFFER_MAX=2000

# CORS (comma-separated origins for web UI)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
