# SpacetimeDB — database name (must match `spacetime publish <name>`)
SPACETIME_DATABASE=devopsai

# Optional: only for running the FastAPI app **on the host** against a local `spacetime start`
# (published module). Do **not** set this when using infra/docker-compose.yml — the backend
# service already uses http://spacetime:3000 on the Compose network.
# SPACETIME_HTTP_URL=http://127.0.0.1:3004

# Google AI Studio — create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id (check AI Studio for current names, e.g. gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Policy: allow docker compose / docker restart style commands in approved runbooks
ALLOW_DOCKER_EXEC=true

# Max lines retained for analysis buffer (must match module trim policy; default 2000)
LOG_BUFFER_MAX=2000

# CORS (comma-separated origins for web UI)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
